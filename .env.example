# Copy this file to ".env" and fill in your Alpaca PAPER trading keys.
# Get free paper keys at https://app.alpaca.markets/  ->  Paper Trading  ->  API Keys
# NEVER commit your real .env file. (.env is gitignored.)

ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# true  = paper trading (safe, fake money)   <-- keep this while developing
# false = LIVE trading with real money       <-- only when you really mean it
ALPACA_PAPER=true

# Optional: push trade alerts to a Slack/Discord incoming webhook.
# Leave blank to only print alerts to the console.
ALERT_WEBHOOK_URL=
